root = true

# すべてのファイルに対する基本設定
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python
[*.py]
indent_style = space
indent_size = 4

# C, C++
[*.{c,h,cpp,hpp,cc,cxx}]
indent_style = space
indent_size = 4

# Rust
[*.rs]
indent_style = space
indent_size = 4

# JavaScript, TypeScript (including jsx and tsx for React)
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# HTML, CSS, JSON, YAML
[*.{html,css,json,yml,yaml}]
indent_style = space
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
